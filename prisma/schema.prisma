generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model StaffMember {
  id           String   @id @default(cuid())
  name         String
  role         String
  department   String
  color        String
  phone        String?
  email        String?
  hoursPerWeek Int?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  shifts       Shift[]
}

model Shift {
  id        String      @id @default(cuid())
  staffId   String
  day       String
  startTime String
  endTime   String
  position  String
  note      String?
  staff     StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model CalendarAssignment {
  id      String @id @default(cuid())
  staffId String
  date    String
}
